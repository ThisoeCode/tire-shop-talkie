{
  "name": "@thisoe/tire-shop-talkie.acc_exe",
  "version": "0.1.0",
  "description": "desktop version of ThisoeCode/tire-shop-talkie powered by Electron",
  "keywords": [
    "electron",
    "jquery"
  ],
  "homepage": "https://github.com/ThisoeCode/tire-shop-talkie#readme",
  "bugs": {
    "url": "https://github.com/ThisoeCode/tire-shop-talkie/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThisoeCode/tire-shop-talkie.git",
    "directory": "acc_exe"
  },
  "license": "MIT",
  "author": "Thisoe",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --windows portable",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "productName": "ACME TIRE",
    "appId": "com.ACME_TIRE.TALKIE",
    "win": {
      "icon": "src/favicon.ico",
      "target": ["portable"]
    },
    "portable": {
      "artifactName": "ACME TIRE.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-reload": "^2.0.0-alpha.1"
  }
}
